{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "kcenon-thread-system",
  "version": "0.1.0",
  "port-version": 0,
  "description": "High-performance C++20 multithreading framework with common_system integration",
  "homepage": "https://github.com/kcenon/thread_system",
  "license": "BSD-3-Clause",
  "supports": "!(uwp | xbox)",
  "dependencies": [
    "simdutf"
  ],
  "overrides": [
    { "name": "simdutf", "version": "5.2.5" },
    { "name": "spdlog", "version": "1.13.0" },
    { "name": "gtest", "version": "1.14.0" },
    { "name": "benchmark", "version": "1.8.3" }
  ],
  "features": {
    "testing": {
      "description": "Build unit tests and benchmarks",
      "dependencies": [
        {
          "name": "gtest",
          "features": ["gmock"]
        },
        "benchmark"
      ]
    },
    "logging": {
      "description": "Enable advanced logging capabilities",
      "dependencies": ["spdlog"]
    },
    "development": {
      "description": "Enable development and debugging tools",
      "dependencies": [
        {
          "name": "gtest",
          "features": ["gmock"]
        },
        "benchmark",
        "spdlog"
      ]
    }
  }
}
